# Local TTS cache tooling config — copy to `config.env` and fill in secrets.
# `config.env` is gitignored (root .gitignore `*.env`); this template is committed.
#
# Only the cache tooling (restore-cache.sh / warm-phrases.sh / status.sh) and
# start-breezyvoice.sh read this. learn-api and the Vite frontend are started the
# normal way (`cargo run`, `pnpm dev:web:run`) with their own env — not from here.

# --- Secrets: Cloudflare R2 (S3-compatible) bucket holding the TTS audio ---
S3_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=<r2-access-key-id>
S3_SECRET_ACCESS_KEY=<r2-secret-access-key>
S3_BUCKET=tts-assets

# --- Postgres access for the restore/warm scripts (k3d pod; no local psql) ---
K8S_CONTEXT=k3d-learn-dev
PG_POD=postgresql-0
DB_NAME=db_app
PGPASSWORD=password

# --- learn-api endpoint (warm-phrases.sh synth calls + status.sh health) ---
LEARN_API_HOST=127.0.0.1
LEARN_API_PORT=4010

# --- BreezyVoice: the OpenAI-compatible Chinese TTS server (start-breezyvoice.sh) ---
BREEZYVOICE_PORT=4051
BREEZYVOICE_DIR=$HOME/git/libs/BreezyVoice

# --- Default language for restore/status/warm (route is /api/tts/<language>) ---
TTS_LANGUAGE=chinese

# --- Cache-key parts for warm-phrases.sh (Chinese resolves to BreezyVoice here;
#     must match the backend's resolve_provider for the phrases page) ---
TTS_PROVIDER=openai-compatible
TTS_VOICE=default
TTS_RATE=n/a
